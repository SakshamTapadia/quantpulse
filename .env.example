# ── Postgres / TimescaleDB ──────────────────────────────────────────────────
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
POSTGRES_DB=quantpulse
POSTGRES_USER=quantpulse
POSTGRES_PASSWORD=changeme

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# ── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_RAW_OHLCV=raw-ohlcv
KAFKA_TOPIC_MACRO=raw-macro
KAFKA_TOPIC_OPTIONS=raw-options
KAFKA_TOPIC_FEATURES=features-computed
KAFKA_TOPIC_REGIME=regime-signal

# ── MLflow ──────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=quantpulse-regime

# ── Data Sources ────────────────────────────────────────────────────────────
POLYGON_API_KEY=your_polygon_key_here
FRED_API_KEY=your_fred_key_here
# yfinance needs no key

# ── Feature Store ───────────────────────────────────────────────────────────
FEATURE_STORE_PATH=/data/features

# ── API Gateway ─────────────────────────────────────────────────────────────
JWT_SECRET=changeme_use_openssl_rand
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ── Environment ─────────────────────────────────────────────────────────────
ENV=development
LOG_LEVEL=INFO
