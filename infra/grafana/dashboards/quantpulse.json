{
  "title": "QuantPulse — System Overview",
  "uid": "quantpulse-overview",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Ingestion records / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 6 },
      "targets": [{
        "expr": "rate(ingestion_records_total[1m]) * 60",
        "legendFormat": "{{source}} / {{data_type}}"
      }]
    },
    {
      "id": 2,
      "title": "Pipeline run duration (p95)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 6 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(feature_pipeline_duration_seconds_bucket[5m]))",
        "legendFormat": "p95 seconds"
      }]
    },
    {
      "id": 3,
      "title": "Regime inferences / min",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 6 },
      "targets": [{
        "expr": "rate(regime_inferences_total[1m]) * 60",
        "legendFormat": "{{ticker}}"
      }]
    },
    {
      "id": 4,
      "title": "Alerts generated",
      "type": "stat",
      "gridPos": { "x": 0, "y": 6, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(alert_generated_total)",
        "legendFormat": "Total alerts"
      }]
    },
    {
      "id": 5,
      "title": "Kafka publish errors",
      "type": "stat",
      "gridPos": { "x": 6, "y": 6, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(ingestion_kafka_published_total{status='error'})",
        "legendFormat": "Publish errors"
      }]
    },
    {
      "id": 6,
      "title": "DB write errors",
      "type": "stat",
      "gridPos": { "x": 12, "y": 6, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(ingestion_db_writes_total{status='error'})",
        "legendFormat": "DB errors"
      }]
    },
    {
      "id": 7,
      "title": "Fetch duration p95 by source",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 10, "w": 12, "h": 6 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(ingestion_fetch_duration_seconds_bucket[5m])) by (source)",
        "legendFormat": "{{source}}"
      }]
    },
    {
      "id": 8,
      "title": "Pipeline runs success vs error",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 10, "w": 12, "h": 6 },
      "targets": [{
        "expr": "sum by (status) (feature_pipeline_runs_total)",
        "legendFormat": "{{status}}"
      }]
    }
  ]
}
